# ============================================================
# CRAFT OCR v3 — Environment Configuration
# Copy to .env and customise for your deployment.
# ============================================================

# GPU --------------------------------------------------------
CUDA_DEVICE=cuda:0

# CRAFT model ------------------------------------------------
CRAFT_LANGUAGES=ch_tra
CRAFT_CANVAS_SIZE=2560
CRAFT_BATCH_SIZE=8
CRAFT_BATCH_TIMEOUT=0.1

# VLM backend ------------------------------------------------
# Options: vllm | gemini | openai
VLM_BACKEND=vllm

# vLLM
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL_NAME=Qwen/Qwen2.5-VL-3B-Instruct

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.0-flash

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4o

# OCR pipeline -----------------------------------------------
OCR_AUTO_ROTATE=true
OCR_REMOVE_PRINT=true
OCR_AUTO_SPLIT=true
OCR_MAX_WORKERS=4
OCR_TIMEOUT=120

# Web server -------------------------------------------------
HOST=0.0.0.0
PORT=8080
WORKERS=1
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20

# Task queue -------------------------------------------------
# REDIS_URL=redis://localhost:6379/0

# Logging ----------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=default
LOG_FILE=
